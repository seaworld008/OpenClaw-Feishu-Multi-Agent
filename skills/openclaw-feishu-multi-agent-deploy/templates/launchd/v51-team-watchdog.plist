<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>bot.molt.v51-team-__TEAM_KEY__</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/env</string>
    <string>python3</string>
    <string>__RECONCILE_SCRIPT__</string>
    <string>--manifest</string>
    <string>__MANIFEST_PATH__</string>
    <string>--team-key</string>
    <string>__TEAM_KEY__</string>
    <string>--openclaw-home</string>
    <string>__OPENCLAW_HOME__</string>
    <string>resume-job</string>
    <string>--stale-seconds</string>
    <string>__STALE_SECONDS__</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__TEAM_WORKDIR__</string>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>60</integer>

  <key>StandardOutPath</key>
  <string>__LOG_DIR__/v51-team-__TEAM_KEY__.stdout.log</string>

  <key>StandardErrorPath</key>
  <string>__LOG_DIR__/v51-team-__TEAM_KEY__.stderr.log</string>
</dict>
</plist>
