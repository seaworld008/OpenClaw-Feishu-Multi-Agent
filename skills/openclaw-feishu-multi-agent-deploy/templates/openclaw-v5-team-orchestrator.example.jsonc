        "peer": {"kind": "group", "id": "oc_7121d87961740dbd72bd8e50e48ba5e3"}
      }
    }
  ],

  "agents": {
    "defaults": {
      "model": {
        "primary": "sub2api/gpt-5.3-codex",
        "fallbacks": ["sub2api/gpt-5.2-codex"]
      },
      "workspace": "~/.openclaw/workspace",
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "sandbox": {
        "sessionToolsVisibility": "all"
      }
    },
    "list": [
      {
        "id": "supervisor_internal_main",
        "name": "奥特曼",
        "workspace": "~/.openclaw/teams/internal_main/workspaces/supervisor",
        "agentDir": "~/.openclaw/teams/internal_main/agents/supervisor/agent",
        "groupChat": {
          "mentionPatterns": ["@奥特曼", "奥特曼", "主管机器人"]
        }
      },
      {
        "id": "ops_internal_main",
        "name": "小龙虾找妈妈",
        "workspace": "~/.openclaw/teams/internal_main/workspaces/ops",
        "agentDir": "~/.openclaw/teams/internal_main/agents/ops/agent"
      },
      {
        "id": "finance_internal_main",
        "name": "易燃易爆",
        "workspace": "~/.openclaw/teams/internal_main/workspaces/finance",
        "agentDir": "~/.openclaw/teams/internal_main/agents/finance/agent"
      },
      {
        "id": "supervisor_external_main",
        "name": "奥特曼",
        "workspace": "~/.openclaw/teams/external_main/workspaces/supervisor",
        "agentDir": "~/.openclaw/teams/external_main/agents/supervisor/agent",
        "groupChat": {
          "mentionPatterns": ["@奥特曼", "奥特曼", "主管机器人"]
        }
      },
      {
        "id": "ops_external_main",
        "name": "小龙虾找妈妈",
        "workspace": "~/.openclaw/teams/external_main/workspaces/ops",
        "agentDir": "~/.openclaw/teams/external_main/agents/ops/agent"
      },
      {
        "id": "finance_external_main",
        "name": "易燃易爆",
        "workspace": "~/.openclaw/teams/external_main/workspaces/finance",
        "agentDir": "~/.openclaw/teams/external_main/agents/finance/agent"
      }
    ]
  },

  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": [
        "supervisor_internal_main",
        "ops_internal_main",
        "finance_internal_main",
        "supervisor_external_main",
        "ops_external_main",
        "finance_external_main"
      ]
    },
    "allow": [
      "group:fs",
      "group:runtime",
      "group:web",
      "group:messaging",
      "group:sessions"
    ],
    "sessions": {
      "visibility": "all"
    }
  },

  "session": {
    "sendPolicy": {
      "default": "allow"
    },
    "resetByType": {
      "group": {
        "mode": "idle",
        "idleMinutes": 1440
      }
    },
    "resetTriggers": ["/reset", "/new"],
    "agentToAgent": {
      "maxPingPongTurns": 0
    }
  },

  "messages": {
    "ackReactionScope": "group-mentions",
    "groupChat": {
      "mentionPatterns": ["@奥特曼", "奥特曼", "主管机器人"]
    }
  }
}
