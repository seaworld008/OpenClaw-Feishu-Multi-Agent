        },
        "yiran_yibao": {
          "appId": "cli_a923c71498b8dcc9",
          "appSecret": "swscrlPKYCwAehOyyoLrlesLTsuYY6nl",
          "groups": {
            "oc_f785e73d3c00954d4ccd5d49b63ef919": {
              "systemPrompt": "你是内部团队财务专家。必须 message(progress) -> message(final) -> sessions_send(COMPLETE_PACKET) -> NO_REPLY。"
            },
            "oc_7121d87961740dbd72bd8e50e48ba5e3": {
              "systemPrompt": "你是外部团队财务专家。必须 message(progress) -> message(final) -> sessions_send(COMPLETE_PACKET) -> NO_REPLY。"
