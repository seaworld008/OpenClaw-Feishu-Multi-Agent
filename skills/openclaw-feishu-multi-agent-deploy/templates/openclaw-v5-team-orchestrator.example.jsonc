      },
      "domain": "feishu",
      "defaultAccount": "aoteman",
      "groups": {
        "oc_f785e73d3c00954d4ccd5d49b63ef919": {
          "requireMention": true
        },
        "oc_7121d87961740dbd72bd8e50e48ba5e3": {
          "requireMention": true
        }
      }
    }
  },

  "bindings": [
    {
      "agentId": "supervisor_internal_main",
      "match": {
        "channel": "feishu",
        "accountId": "aoteman",
        "peer": {"kind": "group", "id": "oc_f785e73d3c00954d4ccd5d49b63ef919"}
      }
    },
    {
      "agentId": "ops_internal_main",
      "match": {
        "channel": "feishu",
        "accountId": "xiaolongxia",
        "peer": {"kind": "group", "id": "oc_f785e73d3c00954d4ccd5d49b63ef919"}
      }
    },
    {
      "agentId": "finance_internal_main",
      "match": {
        "channel": "feishu",
        "accountId": "yiran_yibao",
        "peer": {"kind": "group", "id": "oc_f785e73d3c00954d4ccd5d49b63ef919"}
      }
    },
    {
      "agentId": "supervisor_external_main",
      "match": {
        "channel": "feishu",
        "accountId": "aoteman",
        "peer": {"kind": "group", "id": "oc_7121d87961740dbd72bd8e50e48ba5e3"}
      }
    },
    {
      "agentId": "ops_external_main",
      "match": {
        "channel": "feishu",
        "accountId": "xiaolongxia",
        "peer": {"kind": "group", "id": "oc_7121d87961740dbd72bd8e50e48ba5e3"}
      }
    },
    {
      "agentId": "finance_external_main",
      "match": {
        "channel": "feishu",
