  // 运行时额外信息请查看 v5 runtime manifest。

  "channels": {
    "feishu": {
      "enabled": true,
      "connectionMode": "websocket",
      "accounts": {
        "aoteman": {
          "appId": "cli_a923c749bab6dcba",
          "appSecret": "TWpD207Ri2g1Qqmw4R5YhfkPRhOokCGX",
          "groups": {
            "oc_f785e73d3c00954d4ccd5d49b63ef919": {
              "systemPrompt": "你是内部团队主管 Agent，运行 V5 Team Orchestrator。固定按 workflow.stages 严格串行派发，hidden main=agent:supervisor_internal_main:main。"
            },
            "oc_7121d87961740dbd72bd8e50e48ba5e3": {
              "systemPrompt": "你是外部团队主管 Agent，运行 V5 Team Orchestrator。固定按 workflow.stages 严格串行派发，hidden main=agent:supervisor_external_main:main。"
            }
          }
        },
        "xiaolongxia": {
          "appId": "cli_a9f1849b67f9dcc2",
          "appSecret": "g7dTIRe6Tz8jYzASSKTT2eBV5LGzrKDr",
          "groups": {
            "oc_f785e73d3c00954d4ccd5d49b63ef919": {
              "systemPrompt": "你是内部团队运营专家。必须 message(progress) -> message(final) -> sessions_send(COMPLETE_PACKET) -> NO_REPLY。"
            },
            "oc_7121d87961740dbd72bd8e50e48ba5e3": {
              "systemPrompt": "你是外部团队运营专家。必须 message(progress) -> message(final) -> sessions_send(COMPLETE_PACKET) -> NO_REPLY。"
