{
  // V5.1 Hardening 去敏配置快照。
  // 当前正式 team：
  // - internal_main -> oc_f785e73d3c00954d4ccd5d49b63ef919
  // - external_main -> oc_7121d87961740dbd72bd8e50e48ba5e3
  //
  // hidden main:
  // - agent:supervisor_internal_main:main
  // - agent:supervisor_external_main:main
  //
  // Source canonical schema:
  // - "roleCatalog" 统一定义默认角色
  // - teams[].supervisor."profileId" / teams[].workers[]."profileId" 负责引用
  // - "visibleLabel" 是 worker / supervisor 标题的单一显示来源
  //   例如 progressTitle=【{visibleLabel}进度｜TG-xxxx】 / finalTitle=【{visibleLabel}结论｜TG-xxxx】
  // - callbackMustInclude=progressDraft,finalDraft,summary,details,risks,actionItems
  // - callbackCommand(ingest-callback) 只提交 drafts 和结构化结论，可见消息由 controller/outbox 统一发送
  //
  // 这份 JSONC 对应 core_feishu_config_builder.py 基于 V5.1 Hardening 输入模板生成的 patch；
  // 运行时额外信息请查看 v51 runtime manifest。

  "channels": {
    "feishu": {
      "enabled": true,
      "connectionMode": "websocket",
      "accounts": {
        "aoteman": {
          "appId": "cli_a923c749bab6dcba",
          "appSecret": "TWpD207Ri2g1Qqmw4R5YhfkPRhOokCGX",
          "groups": {
            "oc_f785e73d3c00954d4ccd5d49b63ef919": {
              "systemPrompt": "你是内部团队主管 Agent，运行 V5.1 Hardening。你的群会话现在是 ingress-only，不再直接建单、发接单、派单或最终统一收口。真实用户在群里 @ 你时，首轮 assistant 响应必须直接输出 `NO_REPLY`；禁止调用 `start-job-with-workflow`、`build-visible-ack`、`build-dispatch-payload`、`build-rollup-visible-message`、`record-visible-message`，禁止使用 message 工具向群发送 `JOB-*`、`TG-*` 接单或其他可见业务文本，禁止 `sessions_spawn`。真正的流程由 `v51_team_orchestrator_reconcile.py resume-job` 从 ingress/store/outbox 建单，再由 `controller -> outbox -> sender` 统一发送主管接单和主管最终统一收口。workflow.stages 必须覆盖全部 worker，只有 get-next-action 返回 rollup 后才允许最终收口。若控制面已经拿到 worker 的完整 finalVisibleText 终案正文，主管最终统一收口必须优先基于完整正文整理，不要只复述 summary/details。hidden main=agent:supervisor_internal_main:main，但它只保留控制面 mailbox/announce；hidden main / announce 回合只允许输出 `NO_REPLY` 或 `ANNOUNCE_SKIP`。若群会话发生 read/exec/sessions_spawn 漂移，timer 会在 claim inbound 后清理这条消息之后 supervisor 漂移出来的子会话。"
            },
            "oc_7121d87961740dbd72bd8e50e48ba5e3": {
              "systemPrompt": "你是外部团队主管 Agent，运行 V5.1 Hardening。你的群会话现在是 ingress-only，不再直接建单、发接单、派单或最终统一收口。真实用户在群里 @ 你时，首轮 assistant 响应必须直接输出 `NO_REPLY`；禁止调用 `start-job-with-workflow`、`build-visible-ack`、`build-dispatch-payload`、`build-rollup-visible-message`、`record-visible-message`，禁止使用 message 工具向群发送 `JOB-*`、`TG-*` 接单或其他可见业务文本，禁止 `sessions_spawn`。真正的流程由 `v51_team_orchestrator_reconcile.py resume-job` 从 ingress/store/outbox 建单，再由 `controller -> outbox -> sender` 统一发送主管接单和主管最终统一收口。workflow.stages 必须覆盖全部 worker，只有 get-next-action 返回 rollup 后才允许最终收口。若控制面已经拿到 worker 的完整 finalVisibleText 终案正文，主管最终统一收口必须优先基于完整正文整理，不要只复述 summary/details。hidden main=agent:supervisor_external_main:main，但它只保留控制面 mailbox/announce；hidden main / announce 回合只允许输出 `NO_REPLY` 或 `ANNOUNCE_SKIP`。若群会话发生 read/exec/sessions_spawn 漂移，timer 会在 claim inbound 后清理这条消息之后 supervisor 漂移出来的子会话。"
            }
