{
  // 多机器人 + 多 Agent
  "channels": {
    "feishu": {
      "enabled": true,
      "connectionMode": "websocket",
      "domain": "feishu",
      "defaultAccount": "ops-bot",

      "dmPolicy": "pairing",
      "groupPolicy": "open",
      "requireMention": true,
      "groupCommandMentionBypass": "single_bot",

      "accounts": {
        "ops-bot": {
          "appId": "cli_ops",
          "appSecret": "ops_secret",
          "encryptKey": "ops_encrypt",
          "verificationToken": "ops_token",
          "requireMention": true
        },
        "finance-bot": {
          "appId": "cli_finance",
          "appSecret": "finance_secret",
          "encryptKey": "finance_encrypt",
          "verificationToken": "finance_token",
          "requireMention": false,
          "allowMentionlessInMultiBotGroup": false
        }
      }
    }
  },

  "bindings": [
    {
      "agentId": "ops",
      "match": {
        "channel": "feishu",
        "accountId": "ops-bot",
        "peer": { "kind": "group", "id": "oc_ops_group" }
      }
    },
    {
      "agentId": "finance",
      "match": {
        "channel": "feishu",
        "accountId": "finance-bot",
        "peer": { "kind": "group", "id": "oc_finance_group" }
      }
    },
    {
      // 兜底规则必须放最后
      "agentId": "ops",
      "match": {
        "channel": "feishu",
        "accountId": "ops-bot"
      }
    }
  ],
  "tools": {
    "allow": [
      "group:fs",
      "group:runtime",
      "group:web",
      "group:messaging",
      "group:sessions"
    ],
    "agentToAgent": {
      "enabled": true,
      "allow": ["ops", "finance", "writer", "brainstorm"]
    },
    "sessions": {
      "visibility": "all"
    }
  },
  "session": {
    "sendPolicy": {
      "default": "allow"
    }
  }
}
