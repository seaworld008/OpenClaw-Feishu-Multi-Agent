{
  // 增量 patch 到 ~/.openclaw/openclaw.json（官方插件模式）
  "channels": {
    "feishu": {
      "enabled": true,
      "connectionMode": "websocket",
      "domain": "feishu",
      "defaultAccount": "main",

      "dmPolicy": "pairing",
      "groupPolicy": "open",
      "requireMention": true,
      "groupCommandMentionBypass": "single_bot",

      "accounts": {
        "main": {
          "appId": "cli_xxx",
          "appSecret": "xxx",
          "encryptKey": "xxx",
          "verificationToken": "xxx"
        }
      },

      "groups": {
        "oc_group_a": { "requireMention": false },
        "oc_group_b": { "requireMention": true }
      }
    }
  },

  "bindings": [
    {
      "agentId": "work",
      "match": {
        "channel": "feishu",
        "accountId": "main",
        "peer": { "kind": "group", "id": "oc_group_a" }
      }
    },
    {
      "agentId": "finance",
      "match": {
        "channel": "feishu",
        "accountId": "main",
        "peer": { "kind": "group", "id": "oc_group_b" }
      }
    }
  ],
  "tools": {
    "allow": [
      "group:fs",
      "group:runtime",
      "group:web",
      "group:messaging",
      "group:sessions"
    ],
    "agentToAgent": {
      "enabled": true,
      "allow": ["work", "finance", "writer"]
    },
    "sessions": {
      "visibility": "all"
    }
  },
  "session": {
    "sendPolicy": {
      "default": "allow"
    }
  }
}
