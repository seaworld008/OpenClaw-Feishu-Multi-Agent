{
  "mode": "plugin",
  "defaultAccount": "aoteman",
  "connectionMode": "websocket",
  "messages": {
    "groupChat": {
      "mentionPatterns": ["@奥特曼", "奥特曼", "主管机器人"]
    }
  },
  "tools": {
    "allow": ["group:fs", "group:runtime", "group:web", "group:messaging", "group:sessions"],
    "sessions": {
      "visibility": "all"
    }
  },
  "session": {
    "sendPolicy": {
      "default": "allow"
    }
  },
  "accounts": [
    {
      "accountId": "aoteman",
      "appId": "<replace-aoteman-app-id>",
      "appSecret": "<replace-aoteman-app-secret>"
    },
    {
      "accountId": "xiaolongxia",
      "appId": "<replace-xiaolongxia-app-id>",
      "appSecret": "<replace-xiaolongxia-app-secret>"
    },
    {
      "accountId": "yiran_yibao",
      "appId": "<replace-yiran-yibao-app-id>",
      "appSecret": "<replace-yiran-yibao-app-secret>"
    }
  ],
  "roleCatalog": {
    "supervisor_default": {
      "kind": "supervisor",
      "roleKey": "supervisor",
      "accountId": "aoteman",
      "name": "奥特曼",
      "role": "主管总控",
      "visibleLabel": "主管",
      "description": "主管固定使用 aoteman，负责任务受理、串行调度与最终收口。",
      "responsibility": "接单、拆解、调度、统一收口",
      "identity": {
        "name": "奥特曼总控",
        "theme": "steady orchestrator",
        "emoji": "🧭"
      },
      "systemPrompt": "<replace-supervisor-prompt>"
    },
    "ops_default": {
      "kind": "worker",
      "roleKey": "ops",
      "accountId": "xiaolongxia",
      "name": "小龙虾找妈妈",
      "role": "运营专家",
      "visibleLabel": "运营",
      "description": "运营角色固定使用 xiaolongxia。",
      "responsibility": "活动打法、节奏、执行动作",
      "visibility": "visible",
      "runtime": {
        "model": {
          "primary": "<replace-ops-model>"
        }
      },
      "systemPrompt": "<replace-ops-prompt: use progressDraft/finalDraft and end with CALLBACK_OK>"
    },
    "finance_default": {
      "kind": "worker",
      "roleKey": "finance",
      "accountId": "yiran_yibao",
      "name": "易燃易爆",
      "role": "财务专家",
      "visibleLabel": "财务",
      "description": "财务角色固定使用 yiran_yibao。",
      "responsibility": "预算、毛利、ROI 与风险",
      "visibility": "visible",
      "runtime": {
        "model": {
          "primary": "<replace-finance-model>"
        }
      },
      "systemPrompt": "<replace-finance-prompt: use progressDraft/finalDraft and end with CALLBACK_OK>"
    }
  },
  "teams": [
    {
      "teamKey": "full_team_demo",
      "displayName": "全角色示例群",
      "group": {
        "peerId": "oc_replace_full_team_group",
        "entryAccountId": "aoteman",
        "requireMention": true
      },
      "supervisor": {
        "profileId": "supervisor_default",
        "agentId": "supervisor_full_team_demo"
      },
      "workers": [
        {
          "profileId": "ops_default",
          "agentId": "ops_full_team_demo"
        },
        {
          "profileId": "finance_default",
          "agentId": "finance_full_team_demo"
        }
      ],
      "workflow": {
        "mode": "parallel",
        "stages": [
          {
            "stageKey": "analysis",
            "mode": "parallel",
            "agents": [
              { "agentId": "ops_full_team_demo" },
              { "agentId": "finance_full_team_demo" }
            ],
            "publishOrder": [
              "ops_full_team_demo",
              "finance_full_team_demo"
            ]
          }
        ]
      }
    },
    {
      "teamKey": "ops_only_demo",
      "displayName": "运营单 worker 示例群",
      "group": {
        "peerId": "oc_replace_ops_only_group",
        "entryAccountId": "aoteman",
        "requireMention": true
      },
      "supervisor": {
        "profileId": "supervisor_default",
        "agentId": "supervisor_ops_only_demo"
      },
      "workers": [
        {
          "profileId": "ops_default",
          "agentId": "ops_ops_only_demo",
          "description": "本群只启用运营角色，提示词按群独立配置。",
          "systemPrompt": "<replace-ops-only-ops-prompt>"
        }
      ],
      "workflow": {
        "mode": "serial",
        "stages": [
          { "agentId": "ops_ops_only_demo" }
        ]
      }
    },
    {
      "teamKey": "finance_only_demo",
      "displayName": "财务单 worker 示例群",
      "group": {
        "peerId": "oc_replace_finance_only_group",
        "entryAccountId": "aoteman",
        "requireMention": true
      },
      "supervisor": {
        "profileId": "supervisor_default",
        "agentId": "supervisor_finance_only_demo"
      },
      "workers": [
        {
          "profileId": "finance_default",
          "agentId": "finance_finance_only_demo",
          "description": "本群只启用财务角色，提示词按群独立配置。",
          "systemPrompt": "<replace-finance-only-finance-prompt>"
        }
      ],
      "workflow": {
        "mode": "serial",
        "stages": [
          { "agentId": "finance_finance_only_demo" }
        ]
      }
    }
  ]
}
