{
  "mode": "plugin",
  "bindAddress": "0.0.0.0",
  "port": 8090,
  "connectionMode": "websocket",
  "defaultAccount": "bot-main",
  "dmPolicy": "pairing",
  "groupPolicy": "open",
  "groupAllowFrom": [],
  "allowFrom": [],
  "agents": [
    "work",
    "finance",
    "coder"
  ],
  "accounts": [
    {
      "accountId": "bot-main",
      "appId": "cli_xxx",
      "appSecret": "xxx",
      "encryptKey": "xxx",
      "verificationToken": "xxx"
    }
  ],
  "routes": [
    {
      "agentId": "work",
      "channel": "feishu",
      "accountId": "bot-main",
      "peer": {
        "kind": "group",
        "id": "oc_group_a"
      }
    },
    {
      "agentId": "finance",
      "channel": "feishu",
      "accountId": "bot-main",
      "peer": {
        "kind": "group",
        "id": "oc_group_b"
      }
    }
  ],
  "optional": {
    "requireMention": true,
    "allowMentionlessInMultiBotGroup": false,
    "groupCommandMentionBypass": "single_bot",
    "groups": {
      "oc_group_a": {
        "requireMention": false
      }
    }
  },
  "agentToAgent": {
    "enabled": true,
    "allow": [
      "work",
      "finance",
      "coder"
    ]
  },
  "tools": {
    "allow": [
      "group:fs",
      "group:runtime",
      "group:web",
      "group:messaging",
      "group:sessions"
    ],
    "sessions": {
      "visibility": "all"
    }
  },
  "session": {
    "sendPolicy": {
      "default": "allow"
    }
  },
  "feishu_console_checklist": {
    "event_subscriptions": [
      "im.message.receive_v1",
      "im.chat.member.bot.added_v1",
      "im.chat.member.bot.deleted_v1"
    ],
    "permissions_minimum": [
      "im:message",
      "im:message.p2p_msg:readonly",
      "im:message.group_at_msg:readonly",
      "im:message:send_as_bot",
      "im:resource"
    ],
    "permissions_for_mentionless_group": [
      "im:message.group_msg"
    ]
  }
}
