{
  "mode": "plugin",
  "connectionMode": "websocket",
  "defaultAccount": "main",
  "dmPolicy": "pairing",
  "allowFrom": [],
  "agents": [
    "work",
    "finance"
  ],
  "accounts": [
    {
      "accountId": "main",
      "appId": "cli_xxx",
      "appSecret": "xxx",
      "encryptKey": "xxx",
      "verificationToken": "xxx",
      "overrides": {
        "requireMention": true,
        "groupPolicy": "open"
      }
    },
    {
      "accountId": "assistant",
      "appId": "cli_yyy",
      "appSecret": "yyy",
      "encryptKey": "yyy",
      "verificationToken": "yyy",
      "overrides": {
        "requireMention": false,
        "allowMentionlessInMultiBotGroup": false
      }
    }
  ],
  "routes": [
    {
      "agentId": "work",
      "channel": "feishu",
      "accountId": "main",
      "peer": {
        "kind": "group",
        "id": "oc_group_work"
      }
    },
    {
      "agentId": "finance",
      "channel": "feishu",
      "accountId": "assistant",
      "peer": {
        "kind": "group",
        "id": "oc_group_finance"
      }
    }
  ],
  "agentToAgent": {
    "enabled": true,
    "allow": [
      "work",
      "finance"
    ]
  },
  "tools": {
    "allow": [
      "group:fs",
      "group:runtime",
      "group:web",
      "group:messaging",
      "group:sessions"
    ],
    "sessions": {
      "visibility": "all"
    }
  },
  "session": {
    "sendPolicy": {
      "default": "allow"
    }
  },
  "feishu_console_checklist": {
    "event_subscriptions": [
      "im.message.receive_v1"
    ],
    "permissions_minimum": [
      "im:message",
      "im:message.p2p_msg:readonly",
      "im:message.group_at_msg:readonly",
      "im:message:send_as_bot",
      "im:resource"
    ],
    "permissions_for_mentionless_group": [
      "im:message.group_msg"
    ]
  }
}
