{
  "mode": "core",
  "bindAddress": "0.0.0.0",
  "port": 8090,
  "chatAnywhere": true,
  "apiPath": "/openapi/v2/interactives",
  "agents": [
    "work",
    "finance"
  ],
  "accounts": [
    {
      "accountId": "bot-main",
      "appId": "cli_xxx",
      "appSecret": "xxx",
      "encryptKey": "xxx",
      "verificationToken": "xxx"
    }
  ],
  "routes": [
    {
      "agentId": "work",
      "channel": "chat-feishu",
      "accountId": "bot-main",
      "peer": {
        "kind": "group",
        "id": "oc_group_work"
      }
    },
    {
      "agentId": "finance",
      "channel": "chat-feishu",
      "accountId": "bot-main",
      "peer": {
        "kind": "group",
        "id": "oc_group_finance"
      }
    }
  ],
  "agentToAgent": {
    "enabled": true,
    "allow": [
      "work",
      "finance"
    ]
  },
  "tools": {
    "allow": [
      "group:fs",
      "group:runtime",
      "group:web",
      "group:messaging",
      "group:sessions"
    ],
    "sessions": {
      "visibility": "all"
    }
  },
  "session": {
    "sendPolicy": {
      "default": "allow"
    }
  }
}
